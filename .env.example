# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real secrets.

FYERS_CLIENT_ID=YOUR_CLIENT_ID-100
FYERS_SECRET_KEY=YOUR_SECRET_KEY
FYERS_REDIRECT_URI=https://trade.fyers.in/api-login/redirect-uri/index.html

# --- Headless (TOTP) login — optional, for unattended daily token refresh ---
# SENSITIVE: the TOTP secret bypasses 2FA; PIN + secret = full account access.
# Never commit a real .env. On a server, prefer a secrets manager over plaintext.
FYERS_FY_ID=YOUR_FYERS_ID
FYERS_PIN=YOUR_4_DIGIT_PIN
FYERS_TOTP_SECRET=YOUR_BASE32_TOTP_SECRET
